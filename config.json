{\n  "app": {\n    "name": "Gmail Bulk Sender Pro",\n    "version": "5.0",\n    "language": "bengali",\n    "theme": "dark"\n  },\n  "gmail": {\n    "max_daily_limit": 2600,\n    "max_workers": 5,\n    "emails_per_task": 520,\n    "delay_min": 1.0,\n    "delay_max": 3.0,\n    "warmup_enabled": true\n  },\n  "database": {\n    "name": "sender_pro.db",\n    "auto_backup": true,\n    "backup_interval_hours": 24\n  },\n  "security": {\n    "anti_detection": true,\n    "random_headers": true,\n    "random_message_id": true,\n    "spoof_mailer": true\n  },\n  "presets": {\n    "auto_load": true,\n    "default_type": "sales"\n  }\n}\n